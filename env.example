# IAM App Environment Variables

# API Configuration
# Production / `vite build`: full origin for API (axios uses this + /api).
# Local `vite` dev: axios uses same-origin /api; vite.config.js proxies /api to the backend (see VITE_DEV_PROXY_TARGET).
VITE_API_URL=https://clinical-trial-platform-backend-b6g9bthgbye4hjaj.canadacentral-01.azurewebsites.net
# Optional: override proxy target when running `vite` (default http://localhost:4001)
# VITE_DEV_PROXY_TARGET=http://localhost:4001

# Hub URL (for navigation back)
VITE_HUB_URL=https://blue-pond-0b001410f.2.azurestaticapps.net

# OAuth 2.0 (Authorization Code + PKCE) — IAM is a confidential client of the Hub IdP.
# client_id must match Application.ssoClientId in the backend DB (default: iam_app).
VITE_OAUTH_CLIENT_ID=iam_app
# Must exactly match an entry in Application.ssoRedirectUris.
# Local dev default: http://localhost:5001/callback. Prod: https://iam.dizzaroo.com/callback.
VITE_OAUTH_REDIRECT_URI=https://iam.dizzaroo.com/callback
# Optional: explicit override for the Hub /api/oauth/authorize URL.
# When unset, derived from VITE_API_URL + /api/oauth/authorize (or http://localhost:4001 in dev).
# VITE_OAUTH_AUTHORIZE_URL=https://api.dizzaroo.com/api/oauth/authorize

# Authentication
# Required at runtime — Google OAuth Web client ID (see main.jsx / startup.md)
VITE_GOOGLE_CLIENT_ID=
VITE_TOKEN_STORAGE_KEY=access_token
VITE_USER_STORAGE_KEY=platform_user
VITE_TOKEN_EXPIRY=86400000

# Features
VITE_ENABLE_USER_MANAGEMENT=true
VITE_ENABLE_ROLE_MANAGEMENT=true
VITE_ENABLE_AUDIT_LOGGING=true

# Development
# Set to true to enable dummy login for local development
# When true, you can login without Hub-Login app or backend connection
VITE_DEV_MODE=true

# Build
VITE_APP_VERSION=1.0.0
VITE_APP_NAME=Identity & Access Management

