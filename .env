# IAM App Environment Variables

# API Configuration
# Backend-Clinical-trial-Platform URL
# VITE_API_URL=https://neurodoc-backend-ffe6bzdqhee4c0h6.canadacentral-01.azurewebsites.net

VITE_API_URL=http://localhost:4001
VITE_PLATFORM_SERVICES_URL=http://localhost:5001
# VITE_PLATFORM_SERVICES_URL=https://neurodoc-backend-ffe6bzdqhee4c0h6.canadacentral-01.azurewebsites.net

# Hub URL (for navigation back)
# VITE_HUB_URL=https://blue-pond-0b001410f.2.azurestaticapps.net
VITE_HUB_URL=http://localhost:5000
# Authentication
VITE_TOKEN_STORAGE_KEY=platform_token
VITE_USER_STORAGE_KEY=platform_user
VITE_TOKEN_EXPIRY=86400000

# Features
VITE_ENABLE_USER_MANAGEMENT=true
VITE_ENABLE_ROLE_MANAGEMENT=true
VITE_ENABLE_AUDIT_LOGGING=true

# Development
VITE_DEV_MODE=false
VITE_SHOW_DEBUG=false

# Build
VITE_APP_VERSION=1.0.0
VITE_APP_NAME=Identity & Access Management